# aish — environment template
# Copy to ~/.claude/settings.json env block (preferred) or to a local .env
# DO NOT commit a populated .env. The .gitignore blocks it.

# TensorDock API bearer token
# Create at: https://dashboard.tensordock.com/developers
TENSORDOCK_API_TOKEN=tdk_xxxxxxxxxxxxxxxxxxxx

# Modal authentication is handled by `modal setup` (writes ~/.modal/config.yaml).
# No env var required for the Modal MCP server itself.

# Logging level for both MCP servers (DEBUG | INFO | WARNING | ERROR)
AISH_LOG_LEVEL=INFO
